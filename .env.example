# nuanu-parking-ai environment variables
# Copy this file to .env and fill in real values before running the stack.
# NEVER commit .env to version control — it is gitignored.

# ─────────────────────────────────────────────────────────────
# Telegram Bot (required for alerting)
# ─────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID of the group/channel to send alerts to.
# For groups: usually a negative integer (e.g. -1001234567890)
# Get it by adding @userinfobot to your group
TELEGRAM_CHAT_ID=your_chat_id_here

# ─────────────────────────────────────────────────────────────
# Dashboard Authentication
# ─────────────────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme_use_strong_password

# Cookie signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-random-64-char-hex-string-here

# ─────────────────────────────────────────────────────────────
# MQTT Broker (uses Docker service name as hostname)
# ─────────────────────────────────────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883

# ─────────────────────────────────────────────────────────────
# YOLOv8 Inference
# ─────────────────────────────────────────────────────────────
# Minimum detection confidence to count as a vehicle (0.0–1.0)
# Lower = more detections but more false positives
# Higher = fewer detections but more accurate
YOLO_CONFIDENCE_THRESHOLD=0.65

# ─────────────────────────────────────────────────────────────
# Watchdog
# ─────────────────────────────────────────────────────────────
# Seconds without heartbeat before watchdog fires an alert.
# Counter publishes heartbeat every 60s; set timeout to 1.5× interval = 90s
# This ensures alert fires within NFR-002's 2-minute window worst-case.
HEARTBEAT_TIMEOUT_SECS=90

# ─────────────────────────────────────────────────────────────
# Optional: Frigate
# ─────────────────────────────────────────────────────────────
# Used in Frigate config for RTSP streams if you use a shared password
FRIGATE_RTSP_PASSWORD=
